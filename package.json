    "eslint-plugin-tailwindcss": "^3.18.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "nuxt": "^4.3.1",
    "nuxt-jsonld": "^2.2.1",
    "nuxt-svgo": "4.2.6",
    "nuxt-vitalizer": "^2.0.0",
